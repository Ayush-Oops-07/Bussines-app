# ── Environment ───────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true

# ── Database ──────────────────────────────────────────────────────────
# For SQLite: sqlite+aiosqlite:///./sandeep_traders.db
# For PostgreSQL: postgresql+asyncpg://username:password@localhost:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///./sandeep_traders.db

# ── JWT / Auth ────────────────────────────────────────────────────────
SECRET_KEY=dev-secret-key-change-this-in-production-12345
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
